local TrialState = {}
for diff in pairs(Trials) do
    TrialState[diff] = {
        autoJoin = false,
        walk = false,
        wave = 1,
        leaveWave = 0,
        prevCount = -1,
        capturedPos = nil,
        autoReturn = false,
        teleported = false,
        lastDebug = 0,
        label = nil
    }
end

local function teleportTo(pos)
    local char = LP.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = CFrame.new(pos)
    pcall(function() hrp.AssemblyLinearVelocity = Vector3.new() end)
    task.wait(0.5)
    return (hrp.Position - pos).Magnitude <= 15
end

local function getCountdownLabel(diff)
    local path = Trials[diff].countdownPath
    local obj = WS
    for _, name in ipairs(path) do
        if obj then obj = obj:FindFirstChild(name) end
    end
    if obj and obj:IsA("TextLabel") then return obj end
    return nil
end

local function parseCountdown(text)
    local min = tonumber(text:match("(%d+)m")) or 0
    local sec = tonumber(text:match("(%d+)s")) or 0
    return min * 60 + sec
end

local function updateTrialLabel(diff)
    local st = TrialState[diff]
    if st.label then st.label.Text = "🌊 Wave: " .. st.wave end
end

local function findTrialMob(diff)
    local room = WS:FindFirstChild("__GAME_CONTENT") and
                 WS.__GAME_CONTENT:FindFirstChild("Trials") and
                 WS.__GAME_CONTENT.Trials:FindFirstChild(Trials[diff].room)
    if not room then return nil end
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local bestPart, bestDist = nil, math.huge
    for _, obj in ipairs(room:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 and obj.Parent ~= char then
            local root = obj.Parent:FindFirstChild("HumanoidRootPart") or obj.Parent.PrimaryPart
            if root and root:IsA("BasePart") then
                local d = (hrp.Position - root.Position).Magnitude
                if d < bestDist then bestDist = d; bestPart = root end
            end
        end
    end
    return bestPart
end

