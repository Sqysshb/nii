-- ===== MOVEMENT =====
local activeTween = nil
local function tweenTo(pos, customSpeed)
    local char = LP.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp then return end
    if (Vector3.new(pos.X, 0, pos.Z) - Vector3.new(hrp.Position.X, 0, hrp.Position.Z)).Magnitude <= 3 then return end
    if activeTween then pcall(function() activeTween:Cancel() end); activeTween = nil end
    local speed = customSpeed or S.tweenSpeed
    local tw = TS:Create(hrp, TweenInfo.new(speed, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {CFrame = CFrame.new(pos.X, pos.Y, pos.Z)})
    activeTween = tw
    tw:Play()
    tw.Completed:Wait()
    activeTween = nil
    pcall(function() hrp.AssemblyLinearVelocity = Vector3.new() end)
    if hum then hum.PlatformStand = false; hum.Sit = false end
end

-- ===== ORE DETECTION =====
local function isOreReady(ore)
    if not ore or not ore.Parent then return false end
    if not ore:FindFirstChild("Rock") then return false end
    local ui = ore:FindFirstChild("OresTopUI")
    if ui then local bar = ui:FindFirstChild("Bar")
        if bar then local hp = bar:FindFirstChild("Health")
            if hp and hp.Text == "Respawning..." then return false end
        end
    end
    return true
end

local function getOrePosition(ore)
    local rock = ore:FindFirstChild("Rock")
    if rock and rock:IsA("BasePart") then return rock.Position end
    for _, child in ipairs(ore:GetChildren()) do
        if child:IsA("BasePart") then return child.Position end
    end
    local ok, pivot = pcall(function() return ore:GetPivot() end)
    if ok and pivot then return pivot.Position end
    return nil
end

local function findBestOre()
    local gc = WS:FindFirstChild("__GAME_CONTENT")
    local of = gc and gc:FindFirstChild("Ores")
    if not of then return nil end
    for i = #ORES, 1, -1 do
        if S["m" .. ORES[i]] then
            local children = nil
            pcall(function() children = of:GetChildren() end)
            if not children then return nil end
            for _, o in ipairs(children) do
                if o.Name == ORES[i] and isOreReady(o) then return o end
            end
        end
    end
    return nil
end

local function isInMine()
    local gc = WS:FindFirstChild("__GAME_CONTENT")
    if not gc then return false end
    local of = gc:FindFirstChild("Ores")
    if not of then return false end
    local ok, children = pcall(function() return of:GetChildren() end)
    if not ok or not children then return false end
    return #children > 0
end

local function loop()
    while S.running and not env.NIStop do
        if not isInMine() then task.wait(0.3); continue end
        local any = false
        for _, n in ipairs(ORES) do if S["m"..n] then any = true; break end end
        if not any then task.wait(0.1); continue end
        local ore = findBestOre()
        if not ore then task.wait(0.1); continue end
        local c = LP.Character
        local hrp = c and c:FindFirstChild("HumanoidRootPart")
        local hum = c and c:FindFirstChild("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then task.wait(0.1); continue end
        local orePos = getOrePosition(ore)
        if not orePos then task.wait(0.1); continue end
        tweenTo(orePos)
        if not S.running or env.NIStop then break end
        local waitStart = tick()
        while S.running and not env.NIStop do
            local ready = false
            pcall(function() ready = isOreReady(ore) end)
            if not ready then break end
            if tick() - waitStart > 40 then break end
            task.wait(0.05)
        end
    end
end

-- ===== MOB COMBAT (Realm 3) =====
local MOBS = {"Goblin","Skeleton","Orc","Pirate","Ninja","Warrior","Pirate Captain","Samurai","Pirate Admiral","Dark Commander","Samurai Master","Dark Knight","Ancient Boss"}
local function isMobAlive(mob)
    if not mob or not mob.Parent then return false end
    local hum = mob:FindFirstChildOfClass("Humanoid")
    if not hum then for _, d in ipairs(mob:GetDescendants()) do if d:IsA("Humanoid") then hum = d; break end end end
    return hum and hum.Health > 0
end
local function getMobPosition(mob)
    local hrp = mob:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp.Position end
    for _, d in ipairs(mob:GetDescendants()) do
        if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then return d.Position end
    end
    if mob.PrimaryPart then return mob.PrimaryPart.Position end
    for _, c in ipairs(mob:GetChildren()) do if c:IsA("BasePart") then return c.Position end end
    return nil
end
local function findBestMob()
    local gc = WS:FindFirstChild("__GAME_CONTENT")
    local mf = gc and gc:FindFirstChild("Mobs")
    if not mf then return nil end
    local best, bestHRP, bestHum, bestPri = nil, nil, nil, 0
    for _, m in ipairs(mf:GetChildren()) do
        local pri = 0
        for i = #MOBS, 1, -1 do if m.Name == MOBS[i] and S["c"..MOBS[i]] then pri = i; break end end
        if pri > bestPri then
            local hum = m:FindFirstChildOfClass("Humanoid")
            if not hum then for _, d in ipairs(m:GetDescendants()) do if d:IsA("Humanoid") then hum = d; break end end end
            if hum and hum.Health > 0 then
                local hrp = m:FindFirstChild("HumanoidRootPart")
                if not hrp then for _, d in ipairs(m:GetDescendants()) do if d:IsA("BasePart") and d.Name=="HumanoidRootPart" then hrp=d; break end end end
                if hrp then best, bestHRP, bestHum, bestPri = m, hrp, hum, pri end
            end
        end
    end
    return best, bestHRP, bestHum
end
local function isInRealm3()
    local gc = WS:FindFirstChild("__GAME_CONTENT")
    if not gc then return false end
    local mf = gc:FindFirstChild("Mobs")
    if not mf then return false end
    local ok, children = pcall(function() return mf:GetChildren() end)
    if not ok or not children then return false end
    return #children > 0
end
local function combatLoop()
    while S.combatRunning and not env.NIStop do
        if not isInRealm3() then task.wait(0.3); continue end
        local any = false
        for _, n in ipairs(MOBS) do if S["c"..n] then any = true; break end end
        if not any then task.wait(0.1); continue end
        local char = LP.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then task.wait(0.1); continue end
        local mob, mobHRP, mobHum = findBestMob()
        if not mob then task.wait(0.1); continue end
        while mob and S.combatRunning do
            local mobPos = mobHRP and mobHRP.Position
            if not mobPos then mobPos = getMobPosition(mob) end
            if mobPos and (hrp.Position - mobPos).Magnitude > 5 then
                tweenTo(mobPos, S.combatTweenSpeed)
            end
            local start = tick()
            while S.combatRunning and mob do
                if mobHum and mobHum.Health <= 0 then break end
                if not isMobAlive(mob) then break end
                if tick() - start > 10 then break end
                task.wait(0.05)
            end
            mob, mobHRP, mobHum = findBestMob()
        end
    end
end

-- ===== ANCIENT BOSS =====
local function hasAncientFragment()
    local bp = LP:FindFirstChild("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do
            local n = item.Name:lower()
            if n:find("ancient") or n:find("fragment") or n:find("shard") then return true end
        end
    end
    local char = LP.Character
    if char then
        for _, item in ipairs(char:GetChildren()) do
            local n = item.Name:lower()
            if n:find("ancient") or n:find("fragment") or n:find("shard") then return true end
        end
    end
    return false
end
local function spawnAncientBoss()
    pcall(function()
        local mainRemote = game:GetService("ReplicatedStorage"):FindFirstChild("__Net")
        if mainRemote then
            mainRemote = mainRemote:FindFirstChild("MainRemote")
            if mainRemote and mainRemote:IsA("RemoteEvent") then
                mainRemote:FireServer("SpawnAncientMob", "Supreme Shadow Lord")
            end
        end
    end)
end
local function findAncientBossInstance()
    local gc = WS:FindFirstChild("__GAME_CONTENT")
    if gc then
        for _, m in ipairs(gc:GetDescendants()) do
            if m:IsA("Model") and m ~= LP.Character then
                local n = m.Name:lower()
                if n:find("ancient") or n:find("boss") then
                    if isMobAlive(m) then return m end
                end
            end
        end
    end
    return nil
end
local function ancientBossLoop()
    while S.abossRunning and not env.NIStop do
        if not hasAncientFragment() then
            S.abossStatus = "No Fragment"
            task.wait(10)
            continue
        end
        local boss = findAncientBossInstance()
        if boss then
            S.abossStatus = "Attacking..."
            local c = LP.Character
            local hrp = c and c:FindFirstChild("HumanoidRootPart")
            if not hrp then task.wait(1); continue end
            local bossPos = getMobPosition(boss)
            if not bossPos then task.wait(1); continue end
            if (hrp.Position - bossPos).Magnitude > 6 then
                tweenTo(bossPos, S.combatTweenSpeed)
            end
            if not S.abossRunning or env.NIStop then break end
            local attackStart = tick()
            while S.abossRunning and not env.NIStop and tick() - attackStart < 120 do
                if not isMobAlive(boss) then S.abossStatus = "Defeated!"; task.wait(1); break end
                local t = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
                if t then pcall(function() t:Activate(); t:Deactivate() end) end
                task.wait(0.05)
            end
            continue
        end
        S.abossStatus = "Spawning..."
        spawnAncientBoss()
        task.wait(5)
    end
    S.abossStatus = "Stopped"
end

