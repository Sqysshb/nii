-- Trial Grind + Wave
for diff, data in pairs(Trials) do
    local st = TrialState[diff]
    task.spawn(function()
        while not env.NIStop do
            if st.walk then
                local char = LP.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hum and hrp then
                    local room = WS:FindFirstChild("__GAME_CONTENT") and
                                 WS.__GAME_CONTENT:FindFirstChild("Trials") and
                                 WS.__GAME_CONTENT.Trials:FindFirstChild(data.room)
                    if room then
                        local target = findTrialMob(diff)
                        local aliveCount = 0
                        for _, obj in ipairs(room:GetDescendants()) do
                            if obj:IsA("Humanoid") and obj.Health > 0 and obj.Parent ~= char then
                                aliveCount = aliveCount + 1
                            end
                        end
                        if target then
                            local targetPos = target.Position
                            if (hrp.Position - targetPos).Magnitude > 5 then
                                tweenTo(targetPos, 0.3)
                            end
                        end
                        if st.prevCount > 0 and aliveCount == 0 then
                            st.wave = st.wave + 1
                            print("["..diff.." WAVE] Wave "..st.wave)
                            updateTrialLabel(diff)
                            if st.leaveWave > 0 and st.wave >= st.leaveWave then
                                pcall(function()
                                    local net = RS:FindFirstChild("__Net")
                                    if net then
                                        local main = net:FindFirstChild("MainRemote")
                                        if main then main:FireServer("LeaveTrial") end
                                    end
                                end)
                                if st.autoReturn and st.capturedPos then
                                    teleportTo(st.capturedPos)
                                end
                                st.walk = false
                                pcall(function() Rayfield.Flags["trialWalk_"..diff] = false end)
                            end
                        end
                        st.prevCount = aliveCount
                    end
                end
            end
            task.wait(0.3)
        end
    end)
end

