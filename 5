local function timeTrialLoop()
    local wave = 0
    local notified = false
    local timeCache = 0
    local timeOpen = false
    local mob, mobHum

    while S.ttRunning and not env.NIStop do
        if tick() - timeCache > 5 then
            timeCache = tick()
            local diff, openNow = getNextTrialTime()
            timeOpen = openNow
            if not openNow then
                local m, s = math.floor(diff/60), diff%60
                S.ttStatus = "Hard next: " .. m .. ":" .. string.format("%02d", s)
                if diff <= 120 and not notified then
                    notified = true
                    pcall(function()
                        Rayfield:Notify({Title="Time Trial",Content="Trial in "..m..":"..string.format("%02d",s).."!",Duration=8,Image="info"})
                    end)
                end
            end
        end

        local char = LP.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then task.wait(0.1); continue end

        mob, mobHum = findTrialMob()
        if not mob then
            notified = false
            wave = wave + 1
            S.ttStatus = "Hard w"..wave.." cleared"
            if timeOpen then
                local portalFound = false
                for _, obj in ipairs(WS:GetDescendants()) do
                    if obj:IsA("BasePart") then
                        local gui = obj:FindFirstChildOfClass("BillboardGui") or obj:FindFirstChildOfClass("SurfaceGui")
                        if gui then
                            for _, child in ipairs(gui:GetDescendants()) do
                                if child:IsA("TextLabel") and (child.Text or ""):find("Time Trials", 1, true) then
                                    S.ttStatus = "Entering portal..."
                                    if not isCloseEnough(hrp, obj.Position, 4) then
                                        pcall(tweenTo, Vector3.new(obj.Position.X, obj.Position.Y, obj.Position.Z), S.combatTweenSpeed)
                                    end
                                    if firetouchinterest then pcall(function() firetouchinterest(obj, hrp, 0); firetouchinterest(obj, hrp, 1) end) end
                                    portalFound = true; break
                                end
                            end
                        end
                    end
                    if portalFound then break end
                end
                if portalFound then task.wait(2); continue end
            end
            task.wait(1); continue
        end

        local mobPos = getMobPosition(mob)
        if not mobPos then continue end

        S.ttStatus = "Hard w"..(wave+1).." - "..mob.Name
        if not isCloseEnough(hrp, mobPos, 5) then
            glideTo(mobPos, S.combatTweenSpeed)
        end

        while S.ttRunning and mob do
            if mobHum and mobHum.Health <= 0 then break end
            if not isMobAlive(mob) then break end
            task.wait(0.05)
        end
    end
    S.ttStatus = "Stopped"
end

