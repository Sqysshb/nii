local function getNextTrialTime()
    local now = os.time()
    local tbl = os.date("*t", now)
    local min = tbl.min
    local sec = tbl.sec
    local nextOpen

    if min < 29 or (min == 29 and sec < 0) then
        nextOpen = os.time({year=tbl.year, month=tbl.month, day=tbl.day, hour=tbl.hour, min=29, sec=0})
    elseif min < 30 then
        return 0, true
    elseif min < 59 or (min == 59 and sec < 0) then
        nextOpen = os.time({year=tbl.year, month=tbl.month, day=tbl.day, hour=tbl.hour, min=59, sec=0})
    elseif min < 60 then
        return 0, true
    else
        nextOpen = os.time({year=tbl.year, month=tbl.month, day=tbl.day, hour=tbl.hour+1, min=29, sec=0})
    end

    local diff = nextOpen - now
    if diff <= 0 then return 0, true end
    return diff, false
end

local function findTrialMob()
    local myPos = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    local best, bestDist, bestHum
    local gc = WS:FindFirstChild("__GAME_CONTENT")
    if gc then
        for _, folderName in ipairs({"Mobs", "Trials"}) do
            local folder = gc:FindFirstChild(folderName)
            if folder then
                for _, m in ipairs(folder:GetChildren()) do
                    if isMobAlive(m) then
                        local p = getMobPosition(m)
                        if p and myPos then
                            local d = (p - myPos.Position).Magnitude
                            if not bestDist or d < bestDist then
                                best = m; bestDist = d
                                bestHum = m:FindFirstChildOfClass("Humanoid")
                                if not bestHum then
                                    for _, dd in ipairs(m:GetDescendants()) do
                                        if dd:IsA("Humanoid") then bestHum = dd; break end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return best, bestHum
end

