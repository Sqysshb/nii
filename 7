-- Sqays Hub - Trial Only (Hard)
if _G.HardTrialLoaded then
    _G.HardTrialStop = true
    task.wait(1)
end
_G.HardTrialLoaded = true
_G.HardTrialStop = false

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local WS = game:GetService("Workspace")
local LP = game:GetService("Players").LocalPlayer

local JOIN_COORD = Vector3.new(907.9375, 11.014291763305664, 13443.76953125)

local T = {
    join = false,
    grind = false,
    leave = false,
    leaveMin = 5,
    teleportSuccess = false,
    grinding = false,
    lastJoin = -1,
    lastGrind = -1
}

-- Hard trial odasını bul
local function getRoom()
    local gc = WS:FindFirstChild("__GAME_CONTENT")
    if not gc then return nil end
    local trials = gc:FindFirstChild("Trials")
    if not trials then return nil end
    return trials:FindFirstChild("HardTrialRoom")
end

-- Oda içindeki en yakın mob
local function findMob()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local room = getRoom()
    if not room then return nil end
    local best, bestDist = nil, math.huge
    for _, obj in ipairs(room:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 then
            local root = obj.Parent and (obj.Parent:FindFirstChild("HumanoidRootPart") or obj.Parent.PrimaryPart)
            if root and root:IsA("BasePart") then
                local d = (hrp.Position - root.Position).Magnitude
                if d < bestDist then best, bestDist = root, d end
            end
        end
    end
    return best
end

local function leaveTrial()
    pcall(function()
        game:GetService("ReplicatedStorage"):FindFirstChild("__Net")
            :FindFirstChild("MainRemote"):FireServer("LeaveTrial")
    end)
    T.teleportSuccess = false
end

local function teleport()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = CFrame.new(JOIN_COORD)
    task.wait(0.5)
    if (hrp.Position - JOIN_COORD).Magnitude > 15 then
        warn("[Hard Trial] Teleport failed")
        T.teleportSuccess = false
        return false
    end
    T.teleportSuccess = true
    if T.leave then
        task.delay(T.leaveMin * 60, leaveTrial)
    end
    return true
end

-- Join scheduler
task.spawn(function()
    while T.join and not _G.HardTrialStop do
        local m, s = os.date("*t").min, os.date("*t").sec
        if (m == 29 or m == 59) and s >= 10 and s <= 15 and T.lastJoin ~= m then
            T.lastJoin = m
            teleport()
        end
        if m ~= 29 and m ~= 59 then T.lastJoin = -1 end
        task.wait(1)
    end
end)

-- Grind scheduler
task.spawn(function()
    while T.grind and not _G.HardTrialStop do
        local m, s = os.date("*t").min, os.date("*t").sec
        if (m == 30 or m == 0) and s >= 0 and s <= 5 and T.lastGrind ~= m then
            T.lastGrind = m
            if T.teleportSuccess and not T.grinding then
                T.grinding = true
                task.spawn(function()
                    while T.grind and T.teleportSuccess and not _G.HardTrialStop do
                        local mob = findMob()
                        if mob then
                            local hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
                            if hum then hum:MoveTo(mob.Position) end
                        end
                        task.wait(0.3)
                    end
                    T.grinding = false
                end)
            end
        end
        if m ~= 30 and m ~= 0 then T.lastGrind = -1 end
        task.wait(1)
    end
end)

