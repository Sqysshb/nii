                    end
                    if sec > 0 then st.teleported = false end
                else
                    if os.time() - st.lastLog >= 30 then
                        warn("[AUTO JOIN "..diff.."] Countdown label not found!")
                        st.lastLog = os.time()
                    end
                end
            else
                st.listening = false
            end
        end
